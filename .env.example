# Root-level environment variables example
# Copy to .env and fill in values

# ─── Google Cloud ───────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=vp-dietetic-dev
GOOGLE_CLOUD_REGION=europe-west1

# ─── Artifact Registry ──────────────────────────────────────────────────────
AR_REPOSITORY=vp-dietetic
AR_HOSTNAME=europe-west1-docker.pkg.dev

# Image tags
API_IMAGE=${AR_HOSTNAME}/${GOOGLE_CLOUD_PROJECT}/${AR_REPOSITORY}/api:latest
FRONTEND_IMAGE=${AR_HOSTNAME}/${GOOGLE_CLOUD_PROJECT}/${AR_REPOSITORY}/frontend:latest
