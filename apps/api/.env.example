# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME="VP Dietetic Center API"

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vp_user:vp_password@localhost:5432/vp_dietetic

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=another-secret-for-refresh-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vp-dietetic.fr

# ─── Google Cloud Storage ────────────────────────────────────────────────────
GCS_BUCKET_NAME=vp-dietetic-dev-documents
GOOGLE_CLOUD_PROJECT=vp-dietetic-dev
# En local, pointer vers un fichier service account JSON ou utiliser ADC
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Rate limiting ───────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
