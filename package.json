{
  "name": "vp-dietetic-center",
  "private": true,
  "version": "0.1.0",
  "description": "Application métier pour psycho-nutritionniste — monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "pnpm --filter @vp/api run db:generate",
    "db:migrate": "pnpm --filter @vp/api run db:migrate",
    "db:seed": "pnpm --filter @vp/api run db:seed",
    "db:migrate:init": "pnpm --filter @vp/api run db:migrate -- --name init",
    "db:studio": "pnpm --filter @vp/api prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "turbo": "^2.9.6"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": [
      "eslint --fix --no-error-on-unmatched-pattern"
    ],
    "apps/frontend/src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-error-on-unmatched-pattern"
    ],
    "packages/types/src/**/*.ts": [
      "eslint --fix --no-error-on-unmatched-pattern"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        2,
        "always",
        200
      ]
    }
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
